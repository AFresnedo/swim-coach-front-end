#!/bin/sh
# Same reasoning as .githooks/post-checkout — `git pull`/`git merge` can also
# bulk-change files outside Turbopack's normal one-file-at-a-time watcher
# model, risking a stale dev filesystem cache. We warn instead of
# auto-clearing .next: a running dev server returns 500s until restarted if
# .next is deleted out from under it while it's still up, so this has to
# stay a manual, deliberate step rather than something the hook does for you.
if [ -t 1 ]; then
  bold_yellow='\033[1;33m'
  bold='\033[1m'
  reset='\033[0m'
else
  bold_yellow=''
  bold=''
  reset=''
fi
printf "\n${bold_yellow}WARNING:${reset} merge/pull completed — Turbopack's dev cache may now be stale.\n"
printf "Run: ${bold}rm -rf .next${reset}   then restart your dev server (npm run dev)\n\n"
