# URL of the FastAPI backend (server-side only — never exposed to the browser).
# Optional: defaults to http://localhost:8000 (see lib/back-api.ts) if unset.
# API_URL="http://localhost:8000"

# SITE_INDEXABLE is deliberately not listed here — it's a prod-only launch
# gate with no local-dev use case (nothing crawls localhost). It's owned by
# ../infra/.env.example and wired through docker-compose.yml.

# Cloudflare Turnstile (sign-up CAPTCHA). Get real values from the Cloudflare
# dashboard for staging/prod deploys — see lib note on NEXT_PUBLIC_ vars below.
# Not needed for local dev as long as NEXT_PUBLIC_TURNSTILE_TEST_MODE is "true".
# NEXT_PUBLIC_TURNSTILE_SITE_KEY="your-cloudflare-site-key"
# TURNSTILE_SECRET_KEY="your-cloudflare-secret-key"

# Bypasses the Turnstile widget and server-side verification entirely — no
# script load, no network call to Cloudflare. Restart `next dev` after
# changing this. Never set in ../infra's staging/prod env config, or sign-up
# ships with no CAPTCHA enforcement.
NEXT_PUBLIC_TURNSTILE_TEST_MODE="true"
